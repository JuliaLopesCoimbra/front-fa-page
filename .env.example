# COMET Fan Hub — protótipo front-end, sem backend real (todos os dados vêm
# de /src/mocks). Nenhuma variável é obrigatória para rodar em dev.

# Feature flag do endpoint reservado /internal/picbrand/dashboard (PICBRAND
# ARCH §14). Mantenha "false"; só é ativado centralmente pela Picbrand.
PICBRAND_DASHBOARD_ENABLED=false
